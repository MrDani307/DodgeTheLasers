local function makeButton(parent, text, h)
    local btn = Instance.new("TextButton")
    btn.Parent = parent
    btn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    btn.BackgroundTransparency = 0.82
    btn.Size = UDim2.new(1, 0, 0, h or 40)
    btn.Font = Enum.Font.GothamBold
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(190, 205, 220)
    btn.TextSize = 13
    btn.BorderSizePixel = 0
    btn.AutoButtonColor = false
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 10)
    corner.Parent = btn
    local stroke = Instance.new("UIStroke")
    stroke.Parent = btn
    stroke.Color = Color3.fromRGB(70, 110, 150)
    stroke.Thickness = 1
    stroke.Transparency = 0.6
    local btnHL = Instance.new("Frame")
    btnHL.Parent = btn
    btnHL.BackgroundColor3 = Color3.fromRGB(70, 110, 150)
    btnHL.BackgroundTransparency = 0.75
    btnHL.Position = UDim2.new(0.1, 0, 0, 2)
    btnHL.Size = UDim2.new(0.8, 0, 0, 2)
    btnHL.BorderSizePixel = 0
    local bHLCorner = Instance.new("UICorner")
    bHLCorner.CornerRadius = UDim.new(1, 0)
    bHLCorner.Parent = btnHL

    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundTransparency = 0.6}):Play()
        TweenService:Create(stroke, TweenInfo.new(0.2), {Transparency = 0.3}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.3), {BackgroundTransparency = 0.82}):Play()
        TweenService:Create(stroke, TweenInfo.new(0.3), {Transparency = 0.6}):Play()
    end)
    btn.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.Touch
            or i.UserInputType == Enum.UserInputType.MouseButton1 then
            TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundTransparency = 0.4}):Play()
            TweenService:Create(btn, TweenInfo.new(0.1), {Size = UDim2.new(0.96, 0, 0, (h or 40) - 2)}):Play()
        end
    end)
    btn.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.Touch
            or i.UserInputType == Enum.UserInputType.MouseButton1 then
            TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundTransparency = 0.6}):Play()
            TweenService:Create(btn, TweenInfo.new(0.15), {Size = UDim2.new(1, 0, 0, h or 40)}):Play()
        end
    end)
    return btn, stroke
end

